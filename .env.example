# DriveWebPreviewer ビルド時環境変数のサンプル
# 実値は .env.local（git 管理外）に記入する。機密値はここにも .env.local にも置かない（CLAUDE.md）。

# --- Google Picker 機能用 ---
# Picker 表示用 API キー（用途は「Picker API のみ」に制限）。Drive への権限ではない。
DWP_PICKER_API_KEY=your-picker-api-key
# Google Cloud プロジェクト番号（Picker の AppId）
DWP_GCP_PROJECT_NUMBER=your-gcp-project-number

# --- OAuth サインイン用（launchWebAuthFlow / implicit flow）---
# 「ウェブ アプリケーション」型 OAuth クライアント ID（公開値）。dev / release で別クライアント。
# 承認済みリダイレクト URI に https://<拡張機能ID>.chromiumapp.org/ を登録すること。
DWP_DEV_CLIENT_ID=your-dev-client-id.apps.googleusercontent.com
DWP_RELEASE_CLIENT_ID=your-release-client-id.apps.googleusercontent.com

# --- リリース（ストア公開）ビルド用 ---
# 公開版アイテムの公開鍵（manifest.key・公開/非機密値）。未設定なら build.mjs の既定値を使用。

# dev の拡張機能 ID を固定したい場合のみ（dev 専用公開鍵・1行。release 用とは別の鍵）
# DWP_DEV_KEY=MIIBIjANBgkqhkiG9w0BAQEF...

# 差し替えたい場合のみ設定（公開版インストール先の manifest.json の "key" 等から取得）。
# DWP_RELEASE_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOC...

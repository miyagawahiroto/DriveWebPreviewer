# DriveWebPreviewer 環境変数（雛形）
# 実値は .env.local（git 管理外）にコピーして記入する。値はコミットしない。

# Google Picker 表示用の API キー（GCP で発行・Picker API のみに用途制限すること）
# 注意: Chrome 拡張では配布コードに含まれるため完全秘匿は不可。用途制限で防御する。
DWP_PICKER_API_KEY=

# OAuth クライアント ID は manifest.json に直書き（公開値）。ここには置かない。
# 参考: Google Cloud プロジェクト番号（Picker の AppId に使用）
DWP_GCP_PROJECT_NUMBER=162512121004
